{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "GCC C23",
            "type": "shell",
            "command": "gcc",
            "args": [
                "-std=c23",
                "-Wall",
                "-Wextra",
                "-Werror",
                "-pedantic",
                "${file}",
                "-o",
                "${fileDirname}/${fileBasenameNoExtension}"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}